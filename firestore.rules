rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // User Profiles
    match /users/{userId} {
      // Read stays open to any authenticated user: collabUtils.ts looks up other users'
      // docs by uid for collaborator name/avatar display in shared projects.
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Song Projects & Collaboration
    match /projects/{projectId} {
      function isOwner(data) {
        return data.ownerId == request.auth.uid;
      }
      function isCollaborator(data) {
        return request.auth.uid in data.get("collaborators", []);
      }
      function isMember(data) {
        return isOwner(data) || isCollaborator(data);
      }
      // Lets an invitee read the project (to preview it, see the pending-invite listener in
      // create/page.tsx) and add themself as a collaborator when accepting, before they show
      // up in `collaborators` themselves.
      function isInvited() {
        return exists(/databases/$(database)/documents/invitations/$(projectId + "_" + request.auth.uid)) &&
          get(/databases/$(database)/documents/invitations/$(projectId + "_" + request.auth.uid)).data.inviteeId == request.auth.uid;
      }
      // A user accepting a pending invite adds themself to `collaborators` before the
      // invitation doc is flipped to "accepted" (see handleAcceptInvite in create/page.tsx),
      // so at write time they aren't an owner/collaborator yet — only that one field may change.
      function isAcceptingOwnInvite() {
        return request.resource.data.diff(resource.data).affectedKeys().hasOnly(["collaborators"]) &&
          request.resource.data.collaborators.size() == resource.data.get("collaborators", []).size() + 1 &&
          request.auth.uid in request.resource.data.collaborators &&
          isInvited();
      }

      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow read: if request.auth != null && (isMember(resource.data) || isInvited());
      // Cap total project membership at 5 (owner + 4 collaborators).
      // MAX_COLLABORATORS lives in app/platform/create/collabUtils.ts — keep the literal below in sync.
      allow update: if request.auth != null &&
        (isMember(resource.data) || isAcceptingOwnInvite()) &&
        (
          !("collaborators" in request.resource.data) ||
          request.resource.data.collaborators.size() <= resource.data.get("collaborators", []).size() ||
          request.resource.data.collaborators.size() <= 4
        );
      allow delete: if request.auth != null && isOwner(resource.data);

      // Sub-collection for signaling WebRTC handshake messages
      match /signaling/{signalId} {
        allow read, write: if request.auth != null &&
          isMember(get(/databases/$(database)/documents/projects/$(projectId)).data);
      }

      // Sub-collection for real-time user presence updates
      match /presence/{userId} {
        allow read, write: if request.auth != null &&
          isMember(get(/databases/$(database)/documents/projects/$(projectId)).data);
      }
    }

    // Collaboration Invitations
    match /invitations/{inviteId} {
      function isSenderOrInvitee(data) {
        return data.senderId == request.auth.uid ||
          data.inviteeId == request.auth.uid ||
          (data.inviteeId == "" && data.inviteeEmail == request.auth.token.email);
      }

      allow read, update, delete: if request.auth != null && isSenderOrInvitee(resource.data);
      allow create: if request.auth != null &&
        (request.resource.data.senderId == request.auth.uid || request.resource.data.inviteeId == request.auth.uid);
    }

    // Community / Connect Posts
    match /connect_posts/{postId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // User Feedback Submissions
    match /user_feedback/{feedbackId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null;
    }
  }
}