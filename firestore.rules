rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // User Profiles
    match /users/{userId} {
      // Read stays open to any authenticated user: collabUtils.ts looks up other users'
      // docs by uid for collaborator name/avatar display in shared projects.
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Song Projects & Collaboration
    match /projects/{projectId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      // Cap total project membership at 5 (owner + 4 collaborators).
      // MAX_COLLABORATORS lives in app/platform/create/collabUtils.ts — keep the literal below in sync.
      allow update: if request.auth != null &&
        (
          !("collaborators" in request.resource.data) ||
          request.resource.data.collaborators.size() <= resource.data.get("collaborators", []).size() ||
          request.resource.data.collaborators.size() <= 4
        );
      allow delete: if request.auth != null;
      
      // Sub-collection for signaling WebRTC handshake messages
      match /signaling/{signalId} {
        allow read, write: if request.auth != null;
      }
      
      // Sub-collection for real-time user presence updates
      match /presence/{userId} {
        allow read, write: if request.auth != null;
      }
    }
    
    // Collaboration Invitations
    match /invitations/{inviteId} {
      allow read, write: if request.auth != null;
    }

    // Community / Connect Posts
    match /connect_posts/{postId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // User Feedback Submissions
    match /user_feedback/{feedbackId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null;
    }
  }
}